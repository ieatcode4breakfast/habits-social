{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing public information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number", "description": "server timestamp" }
      },
      "required": ["email", "displayName", "createdAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "A friendship connection or request between two users",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of exactly 2 user UIDs"
        },
        "initiatorId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "number", "description": "server timestamp" },
        "updatedAt": { "type": "number", "description": "server timestamp" }
      },
      "required": ["participants", "initiatorId", "receiverId", "status", "createdAt", "updatedAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit to track",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "sharedWith": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of friend UIDs who can see this habit. Max 100."
        },
        "createdAt": { "type": "number", "description": "server timestamp" },
        "updatedAt": { "type": "number", "description": "server timestamp" }
      },
      "required": ["ownerId", "title", "color", "sharedWith", "createdAt", "updatedAt"]
    },
    "HabitLog": {
      "title": "HabitLog",
      "description": "A daily log for a specific habit",
      "type": "object",
      "properties": {
        "habitId": { "type": "string" },
        "ownerId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "status": { "type": "string", "enum": ["completed", "skipped", "failed"] },
        "updatedAt": { "type": "number", "description": "server timestamp" }
      },
      "required": ["habitId", "ownerId", "date", "status", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Publically readable to find friends."
    },
    "friendships/{friendshipId}": {
      "schema": { "$ref": "#/entities/Friendship" },
      "description": "Friendships map. Can be queried to find friends."
    },
    "habits/{habitId}": {
      "schema": { "$ref": "#/entities/Habit" },
      "description": "Habit metadata."
    },
    "habitLogs/{logId}": {
      "schema": { "$ref": "#/entities/HabitLog" },
      "description": "Records representing a specific day's habit completion status."
    }
  }
}
